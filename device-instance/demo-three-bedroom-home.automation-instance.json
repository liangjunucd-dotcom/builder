  "automations": [
    {
      "name": "主卧夜间有人开灯",
      "starters": [
        {
          "type": "property.event",
          "source": {
            "type": "data.ref",
            "from": "/metadata/scope",
            "select": {
              "by": "name",
              "value": "masterBedroomMotion"
            }
          },
          "is": true,
          "for": "5sec",
          "suppressFor": "30sec"
        }
      ],
      "condition": {
        "type": "and",
        "conditions": [
          {
            "type": "time.between",
            "after": "18:00",
            "before": "06:00"
          },
          {
            "type": "property.state",
            "source": {
              "type": "device.property",
              "deviceId": "dev.master_bedroom.light",
              "endpointId": 1,
              "functionCode": "Output",
              "traitCode": "OnOff"
            },
            "is": false
          }
        ]
      },
      "actions": [
        {
          "type": "device.trait.write",
          "functionCode": "Output",
          "traitCode": "OnOff",
          "targets": [
            {
              "deviceId": "dev.master_bedroom.light",
              "endpointIds": [1]
            }
          ],
          "value": true
        }
      ]
    },
